APP_NAME="CSE-326 Tweet API"
API_V1_PREFIX="/api/v1"
CORS_ORIGINS='["http://localhost:5173"]'
APP_URL="http://localhost:8000"

# Supabase
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# JWT
JWT_SECRET="your-long-random-secret-here"

# OpenRouter AI
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_MODEL="google/gemma-3-4b-it:free"

# Pollinations Image Generation
POLLINATIONS_IMAGE_ENDPOINT="https://gen.pollinations.ai/v1/images/generations"
POLLINATIONS_IMAGE_MODEL="flux"
POLLINATIONS_IMAGE_SIZE="1024x1024"
POLLINATIONS_IMAGE_QUALITY="medium"
POLLINATIONS_IMAGE_TIMEOUT_SECONDS="120"
POLLINATIONS_API_KEY="your-pollinations-api-key"
